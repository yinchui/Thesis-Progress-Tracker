{
  "appId": "com.thesis-tracker.app",
  "productName": "Thesis Progress Tracker",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-Setup-${version}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
